{
  "name": "grateful-grabber",
  "version": "3.0.0",
  "description": "Grateful Grabber",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisbendel/grateful-grabber"
  },
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "package": "npm run build && npm run package:chrome && npm run package:firefox && npm run package:source",
    "package:chrome": "cd dist/chrome && zip -qr ../../grateful-grabber-chrome.zip .",
    "package:firefox": "cd dist/firefox && zip -qr ../../grateful-grabber-firefox.zip .",
    "package:source": "zip -qr grateful-grabber-source.zip . -x 'node_modules/*' -x 'dist/*' -x '.git/*' -x '.github/*' -x 'web-ext-artifacts/*' -x '*.zip'",
    "lint": "eslint src --ext .ts,.tsx",
    "build:chrome": "tsc --noEmit && cross-env BROWSER=chrome vite build && cross-env BROWSER=chrome vite build --config vite.content.config.ts",
    "build:firefox": "tsc --noEmit && cross-env BROWSER=firefox vite build && cross-env BROWSER=firefox vite build --config vite.content.config.ts",
    "build:hmr": "rollup --config utils/reload/rollup.config.ts",
    "wss": "node utils/reload/initReloadServer.js",
    "dev": "npm run build:hmr && (run-p wss build:watch:main:chrome build:watch:content:chrome)",
    "dev:chrome": "npm run build:hmr && (run-p wss build:watch:main:chrome build:watch:content:chrome)",
    "dev:firefox": "npm run build:hmr && (run-p wss build:watch:main:firefox build:watch:content:firefox web-ext:run)",
    "build:watch:main:chrome": "cross-env BROWSER=chrome __DEV__=true vite build --watch",
    "build:watch:main:firefox": "cross-env BROWSER=firefox __DEV__=true vite build --watch",
    "build:watch:content:chrome": "cross-env BROWSER=chrome __DEV__=true vite build --config vite.content.config.ts --watch",
    "build:watch:content:firefox": "cross-env BROWSER=firefox __DEV__=true vite build --config vite.content.config.ts --watch",
    "web-ext:run": "web-ext run --source-dir dist/firefox",
    "test": "jest"
  },
  "type": "module",
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^8.5.0",
    "@types/chrome": "0.0.224",
    "@types/jest": "29.0.3",
    "@types/lodash-es": "^4.17.8",
    "@types/node": "20.2.5",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.0.11",
    "@types/webextension-polyfill": "^0.12.5",
    "@types/ws": "^8.5.4",
    "@typescript-eslint/eslint-plugin": "5.59.11",
    "@typescript-eslint/parser": "5.38.1",
    "@vitejs/plugin-react": "2.2.0",
    "chokidar": "^3.5.3",
    "cross-env": "^7.0.3",
    "eslint": "8.41.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-react": "7.32.2",
    "fs-extra": "11.1.1",
    "jest": "29.0.3",
    "jest-environment-jsdom": "29.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "2.8.8",
    "rollup": "2.79.1",
    "sass": "1.62.1",
    "ts-jest": "29.0.2",
    "ts-loader": "9.4.3",
    "typescript": "5.0.4",
    "vite": "3.1.3",
    "web-ext": "^10.0.0",
    "ws": "8.13.0"
  }
}
